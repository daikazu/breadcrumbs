{
    "name": "daikazu/breadcrumbs",
    "description": "Route-aware breadcrumb management for Laravel",
    "keywords": [
        "Daikazu",
        "laravel",
        "breadcrumbs"
    ],
    "homepage": "https://github.com/daikazu/breadcrumbs",
    "license": "MIT",
    "authors": [
        {
            "name": "Mike Wall",
            "email": "daikazu@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/support": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/view": "^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^v1.29",
        "nunomaduro/collision": "^8.9",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "Daikazu\\Breadcrumbs\\": "src/",
            "Daikazu\\Breadcrumbs\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Daikazu\\Breadcrumbs\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Daikazu\\Breadcrumbs\\BreadcrumbsServiceProvider"
            ],
            "aliases": {
                "Breadcrumbs": "Daikazu\\Breadcrumbs\\Facades\\Breadcrumbs"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
